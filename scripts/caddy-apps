#!/bin/bash

# Caddy Apps Manager
# Centralized management of local development apps with HTTPS

set -e

CONFIG_FILE="$HOME/.caddy-apps/apps.conf"
CADDYFILE="$HOME/.caddy-apps/Caddyfile"
LOGS_DIR="$HOME/.caddy-apps/logs"
HOSTS_MARKER="# CADDY-APPS-MANAGED"
CADDY_BIN="/opt/homebrew/bin/caddy"
REPOS_DIR="$HOME/github/dbckz/claude"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

log_info() { echo -e "${BLUE}▸${NC} $1"; }
log_success() { echo -e "${GREEN}✓${NC} $1"; }
log_warn() { echo -e "${YELLOW}⚠${NC} $1"; }
log_error() { echo -e "${RED}✗${NC} $1"; }

# Parse config file
parse_config() {
    grep -v '^#' "$CONFIG_FILE" 2>/dev/null | grep -v '^$' | grep '=' || true
}

# Get port for app
get_port() {
    local name=$1
    grep "^${name}=" "$CONFIG_FILE" 2>/dev/null | cut -d'=' -f2 | xargs || echo ""
}

# Generate Caddyfile
generate_caddyfile() {
    log_info "Generating Caddyfile..."

    mkdir -p "$LOGS_DIR"

    cat > "$CADDYFILE" << 'HEADER'
# Auto-generated by caddy-apps
# Do not edit directly - edit ~/.caddy-apps/apps.conf instead

{
    local_certs
    admin localhost:2019
    pki {
        ca local {
            intermediate_lifetime 43800h
        }
    }
}

HEADER

    while IFS='=' read -r name port; do
        [ -z "$name" ] && continue
        name=$(echo "$name" | xargs)
        port=$(echo "$port" | xargs)

        cat >> "$CADDYFILE" << ENTRY
${name}.localhost {
    tls internal
    reverse_proxy localhost:${port}
    log {
        output file ${LOGS_DIR}/${name}.log {
            roll_size 10mb
            roll_keep 3
        }
    }
}

ENTRY
        log_success "  ${name}.localhost → localhost:${port}"
    done < <(parse_config)

    # Append static site configs if they exist
    local static_conf="$HOME/.caddy-apps/static.conf"
    if [ -f "$static_conf" ]; then
        grep -v '^#' "$static_conf" | grep -v '^$' > /dev/null 2>&1 && {
            echo "" >> "$CADDYFILE"
            cat "$static_conf" >> "$CADDYFILE"
            log_success "  Appended static site configs"
        }
    fi
}

# Update /etc/hosts
update_hosts() {
    log_info "Updating /etc/hosts..."

    local new_entries="$HOSTS_MARKER START"
    while IFS='=' read -r name port; do
        [ -z "$name" ] && continue
        name=$(echo "$name" | xargs)
        new_entries="$new_entries
127.0.0.1 ${name}.localhost"
    done < <(parse_config)

    # Add static site domains from static.conf
    local static_conf="$HOME/.caddy-apps/static.conf"
    if [ -f "$static_conf" ]; then
        while read -r line; do
            local domain=$(echo "$line" | sed 's/ {$//' | xargs)
            if [ -n "$domain" ]; then
                new_entries="$new_entries
127.0.0.1 ${domain}"
            fi
        done < <(grep '\.localhost {' "$static_conf")
    fi
}

# Start Caddy
start_caddy() {
    if pgrep -x caddy > /dev/null; then
        log_warn "Caddy is already running"
        return
    fi

    if [ ! -f "$CADDYFILE" ]; then
        log_error "Caddyfile not found. Run 'caddy-apps reload' first."
        exit 1
    fi

    log_info "Starting Caddy..."
    $CADDY_BIN start --config "$CADDYFILE"
    log_success "Caddy started"
}

# Stop Caddy
stop_caddy() {
    log_info "Stopping Caddy..."
    $CADDY_BIN stop 2>/dev/null || pkill caddy 2>/dev/null || true
    log_success "Caddy stopped"
}

# Reload Caddy
reload_caddy() {
    log_info "Reloading Caddy..."

    if pgrep -x caddy > /dev/null; then
        $CADDY_BIN reload --config "$CADDYFILE" 2>/dev/null || {
            log_warn "Reload failed, restarting Caddy..."
            stop_caddy
            sleep 1
            start_caddy
        }
    else
        log_info "Caddy not running, starting it..."
        start_caddy
    fi

    log_success "  Caddy reloaded"
}

# Full reload
reload() {
    echo ""
    log_info "Reloading caddy-apps configuration..."
    echo ""

    generate_caddyfile
    cleanup_hosts
    reload_caddy

    echo ""
    log_success "Configuration reloaded!"
    echo ""
    list_apps
}

# List apps
list_apps() {
    echo ""
    echo "Configured Local Apps"
    echo "====================="
    echo ""
    printf "%-20s %-10s %s\n" "URL" "PORT" "STATUS"
    printf "%-20s %-10s %s\n" "---" "----" "------"

    while IFS='=' read -r name port; do
        [ -z "$name" ] && continue
        name=$(echo "$name" | xargs)
        port=$(echo "$port" | xargs)

        if curl -s -o /dev/null -w "%{http_code}" "http://localhost:$port" 2>/dev/null | grep -q "200\|301\|302\|304"; then
            status="${GREEN}●${NC} up"
        else
            status="${RED}●${NC} down"
        fi

        printf "%-20s %-10s " "https://${name}.localhost" "$port"
        echo -e "$status"
    done < <(parse_config)
    echo ""
}

# Add app
add_app() {
    local name=$1
    local port=$2

    if [ -z "$name" ] || [ -z "$port" ]; then
        log_error "Usage: caddy-apps add <name> <port>"
        exit 1
    fi

    if grep -q "^${name}=" "$CONFIG_FILE" 2>/dev/null; then
        log_warn "App '$name' already exists. Updating port to $port"
        sed -i '' "s/^${name}=.*/${name}=${port}/" "$CONFIG_FILE"
    else
        echo "${name}=${port}" >> "$CONFIG_FILE"
        log_success "Added ${name}.localhost → localhost:${port}"
    fi

    reload
}

# Remove app
remove_app() {
    local name=$1

    if [ -z "$name" ]; then
        log_error "Usage: caddy-apps remove <name>"
        exit 1
    fi

    if grep -q "^${name}=" "$CONFIG_FILE" 2>/dev/null; then
        sed -i '' "/^${name}=/d" "$CONFIG_FILE"
        log_success "Removed ${name}"
        reload
    else
        log_error "App '$name' not found"
        exit 1
    fi
}

# Validate config
validate() {
    echo ""
    log_info "Validating caddy-apps configuration..."
    echo ""

    local errors=0
    local warnings=0

    # Check config file exists
    if [ ! -f "$CONFIG_FILE" ]; then
        log_error "Config file not found: $CONFIG_FILE"
        ((errors++))
    else
        log_success "Config file: $CONFIG_FILE"
    fi

    # Check for duplicate ports
    local ports=$(parse_config | cut -d'=' -f2 | sort)
    local dup=$(echo "$ports" | uniq -d)
    if [ -n "$dup" ]; then
        log_error "Duplicate port assignments: $dup"
        ((errors++))
    else
        log_success "No duplicate port assignments"
    fi

    # Check for port conflicts
    while IFS='=' read -r name port; do
        [ -z "$name" ] && continue
        name=$(echo "$name" | xargs)
        port=$(echo "$port" | xargs)

        if lsof -i ":$port" > /dev/null 2>&1; then
            local pid=$(lsof -ti ":$port" 2>/dev/null)
            if [ -n "$pid" ]; then
                log_warn "Port $port ($name): In use by PID $pid"
                ((warnings++))
            fi
        fi
    done < <(parse_config)

    # Check Caddy status
    if pgrep -x caddy > /dev/null; then
        local pid=$(pgrep -x caddy)
        log_success "Caddy: Running (PID $pid)"
    else
        log_warn "Caddy: Not running"
        ((warnings++))
    fi

    # Check /etc/hosts for stale entries
    if grep -q "$HOSTS_MARKER" /etc/hosts 2>/dev/null; then
        log_warn "Stale .local entries in /etc/hosts (run: caddy-apps reload to clean up)"
        ((warnings++))
    else
        log_success "No stale /etc/hosts entries"
    fi

    echo ""
    if [ $errors -eq 0 ] && [ $warnings -eq 0 ]; then
        log_success "All checks passed!"
    else
        echo "Summary: $warnings warnings, $errors errors"
    fi
    echo ""
}

# Get port for app
port_cmd() {
    local name=$1
    if [ -z "$name" ]; then
        log_error "Usage: caddy-apps port <name>"
        exit 1
    fi

    local port=$(get_port "$name")
    if [ -z "$port" ]; then
        log_error "App '$name' not found in config"
        exit 1
    fi

    echo "$port"
}

# Get URL for app
url_cmd() {
    local name=$1
    if [ -z "$name" ]; then
        log_error "Usage: caddy-apps url <name>"
        exit 1
    fi

    local port=$(get_port "$name")
    if [ -z "$port" ]; then
        log_error "App '$name' not found in config"
        exit 1
    fi

    echo "https://${name}.localhost"
}

# List all ports
ports_cmd() {
    echo ""
    echo "Port Assignments"
    echo "================"
    echo ""

    while IFS='=' read -r name port; do
        [ -z "$name" ] && continue
        name=$(echo "$name" | xargs)
        port=$(echo "$port" | xargs)
        printf "%-20s %s\n" "${name}:" "$port"
    done < <(parse_config)
    echo ""
}

# Cleanup old instances
cleanup() {
    echo ""
    log_info "Cleaning up old Caddy instances..."
    echo ""

    # Stop all Caddy processes
    pkill caddy 2>/dev/null || true
    sleep 1

    if pgrep -x caddy > /dev/null; then
        log_warn "Some Caddy processes still running (may need sudo)"
    else
        log_success "All Caddy processes stopped"
    fi

    # Disable Homebrew service
    if brew services list | grep -q "caddy.*started"; then
        brew services stop caddy 2>/dev/null || true
        log_success "Homebrew Caddy service disabled"
    fi

    echo ""
}

# Sync .env.local files to repos
sync_envs() {
    echo ""
    log_info "Syncing .env.local files to repos..."
    echo ""

    while IFS='=' read -r name port; do
        [ -z "$name" ] && continue
        name=$(echo "$name" | xargs)
        port=$(echo "$port" | xargs)

        local repo_dir="$REPOS_DIR/$name"
        if [ -d "$repo_dir" ]; then
            cat > "$repo_dir/.env.local" << EOF
# Auto-generated by caddy-apps
# Source: ~/.caddy-apps/apps.conf
PORT=$port
APP_URL=https://${name}.localhost
EOF
            log_success "  Generated $repo_dir/.env.local"
        else
            log_warn "  Repo not found: $repo_dir"
        fi
    done < <(parse_config)

    echo ""
    log_success "Sync complete!"
    echo ""
}

# Initialize
init() {
    echo ""
    log_info "Initializing caddy-apps..."
    echo ""

    # Create directories
    mkdir -p "$HOME/.caddy-apps/logs"
    log_success "Created ~/.caddy-apps/"

    # Create config if doesn't exist
    if [ ! -f "$CONFIG_FILE" ]; then
        cat > "$CONFIG_FILE" << 'EOF'
# Caddy Apps Configuration
# Format: name=port
# Access apps at https://name.localhost
#
# Port Allocation Guide:
#   3001-3010: Node.js/Next.js apps
#   5000-5099: Python Flask apps
#   8000-8099: Python FastAPI apps

# Node.js Apps
calendar=3001
weeknotes=3002
linkedin=3003
policy-explorer=3004

# Python Apps
tracker=5050
1001albums=8000
EOF
        log_success "Created $CONFIG_FILE"
    else
        log_info "Config already exists: $CONFIG_FILE"
    fi

    # Generate and reload
    reload

    # Trust CA
    log_info "Trusting Caddy CA (for HTTPS)..."
    $CADDY_BIN trust 2>/dev/null || log_warn "Could not trust CA automatically. You may see HTTPS warnings."

    echo ""
    log_success "Initialization complete!"
    log_info "Apps configured at https://<name>.localhost"
    echo ""
}

# Show status
show_status() {
    echo ""
    echo "Caddy Apps Status"
    echo "================="
    echo ""

    if pgrep -x caddy > /dev/null; then
        log_success "Caddy: running"
    else
        log_error "Caddy: stopped"
    fi

    echo ""
    list_apps
}

# Tail logs
tail_logs() {
    local name=$1
    if [ -z "$name" ]; then
        log_error "Usage: caddy-apps logs <name>"
        exit 1
    fi

    local logfile="$LOGS_DIR/${name}.log"
    if [ -f "$logfile" ]; then
        tail -f "$logfile"
    else
        log_error "No logs found for '$name'"
        exit 1
    fi
}

# Edit config
edit_config() {
    ${EDITOR:-nano} "$CONFIG_FILE"
}

# Show help
show_help() {
    cat << EOF
Caddy Apps Manager - HTTPS reverse proxy for local development

Usage: caddy-apps <command> [args]

Commands:
    init                  First-time setup
    reload                Regenerate config and reload Caddy
    add <name> <port>     Add a new app
    remove <name>         Remove an app
    list                  List all configured apps
    status                Show Caddy status

    port <name>           Show port for app
    url <name>            Show URL for app
    ports                 List all port assignments

    validate              Check for conflicts and issues
    cleanup               Stop old Caddy instances
    sync-envs             Generate .env.local files in repos

    start                 Start Caddy
    stop                  Stop Caddy
    logs <name>           Tail logs for app
    edit                  Edit config file
    help                  Show this help

Config: ~/.caddy-apps/apps.conf
Access apps at: https://<name>.localhost

Examples:
    caddy-apps init                    # First-time setup
    caddy-apps add myapi 8080          # Add app
    caddy-apps reload                  # Apply changes
    caddy-apps list                    # Show all apps
    caddy-apps logs calendar           # View logs

EOF
}

# Main command handler
case "${1:-}" in
    init)
        init
        ;;
    reload)
        reload
        ;;
    add)
        add_app "$2" "$3"
        ;;
    remove|rm)
        remove_app "$2"
        ;;
    list|ls)
        list_apps
        ;;
    status)
        show_status
        ;;
    port)
        port_cmd "$2"
        ;;
    url)
        url_cmd "$2"
        ;;
    ports)
        ports_cmd
        ;;
    validate)
        validate
        ;;
    cleanup)
        cleanup
        ;;
    sync-envs)
        sync_envs
        ;;
    start)
        start_caddy
        ;;
    stop)
        stop_caddy
        ;;
    logs)
        tail_logs "$2"
        ;;
    edit)
        edit_config
        ;;
    help|--help|-h|"")
        show_help
        ;;
    *)
        log_error "Unknown command: $1"
        show_help
        exit 1
        ;;
esac
